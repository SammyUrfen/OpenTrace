#!/usr/bin/env bash
# otrace — wrap ONE foreground command under strace and report its lifecycle to
# the OpenTrace backend. Invoked transparently by the shell hook as:
#
#     otrace -- <command> [args...]
#
# Design (from the interception-design synthesis):
#   * The shell forks THIS as a normal foreground job, so quoting, job control,
#     $?, and Ctrl-C are 100% native — there is no inner `bash -c` re-parse.
#   * strace runs as our child (we stay alive to wait + finalize); we report
#     strace's pid both on disk (<run_dir>/strace.pid) and via HTTP so the
#     psutil poller can watch the real process subtree.
#   * Everything is FAIL-OPEN: if the backend is down or curl/strace is missing,
#     the command still runs, untraced. The backend never blocks the user.
#   * Exit status is decoupled from HTTP: we always `exit` with the command's
#     real status, regardless of whether /runs/end succeeded.
set -u

API="${OPENTRACE_API:-http://localhost:8000}"

# Drop the leading `--` the hook passes.
[ "${1:-}" = "--" ] && shift
[ "$#" -eq 0 ] && exit 0

# Re-entrancy guard: a traced program that itself spawns a hooked shell must not
# double-wrap (the outer `strace -f` already follows children).
if [ -n "${OPENTRACE_IN_RUN:-}" ]; then exec "$@"; fi

# Without curl we can't talk to the backend — just run the command.
command -v curl >/dev/null 2>&1 || exec "$@"

_json_escape() {  # escape $1 as a JSON string body (no surrounding quotes)
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

_field() {  # _field <json> <key> -> value (string fields only)
  printf '%s' "$1" | grep -o "\"$2\":\"[^\"]*\"" | head -1 | cut -d'"' -f4
}

cmd_j="$(_json_escape "$*")"
cwd_j="$(_json_escape "$PWD")"
payload="{\"command\":\"$cmd_j\",\"cwd\":\"$cwd_j\""
[ -n "${OPENTRACE_SESSION:-}" ] && payload="$payload,\"session_id\":\"$OPENTRACE_SESSION\""
[ -n "${OPENTRACE_TERMINAL:-}" ] && payload="$payload,\"terminal_id\":\"$OPENTRACE_TERMINAL\""
# No collector_config here on purpose: the backend fills it from the live config
# (config.tracing.collectors) so the Live Monitor's collector toggles take effect.
payload="$payload}"

resp="$(curl -sf --max-time 2 -X POST "$API/runs/start" \
    -H 'content-type: application/json' -d "$payload" 2>/dev/null)"
[ -z "$resp" ] && exec "$@"          # backend down -> fail open

run_id="$(printf '%s' "$resp" | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)"
run_dir="$(_field "$resp" run_dir)"
log="$(_field "$resp" strace_log_path)"
{ [ -z "$run_id" ] || [ -z "$log" ]; } && exec "$@"

# Which collectors are enabled for this run (from the /start response).
use_strace="$(printf '%s' "$resp" | grep -o '"strace":[a-z]*' | head -1 | cut -d: -f2)"
use_ltrace="$(printf '%s' "$resp" | grep -o '"ltrace":[a-z]*' | head -1 | cut -d: -f2)"
use_perf="$(printf '%s' "$resp" | grep -o '"perf":[a-z]*' | head -1 | cut -d: -f2)"

export OPENTRACE_IN_RUN="$run_id"

# Build the trace command. strace and ltrace both use ptrace, so they are
# mutually exclusive — ltrace mode wins if both are somehow set. `ltrace -S`
# logs library calls (malloc/free + the hotspot table) AND @SYS syscalls.
# strace's `-e write=1,2` dumps stdout/stderr bytes into the log so the Logs tab
# can reconstruct output WITHOUT teeing the fds (stdio/isatty stay native).
inner=("$@")
if [ "$use_ltrace" = "true" ] && [ -n "$run_dir" ] && command -v ltrace >/dev/null 2>&1; then
  inner=(ltrace -S -f -ttt -T -o "$run_dir/ltrace.log" -- "$@")
elif [ "$use_strace" != "false" ] && command -v strace >/dev/null 2>&1; then
  inner=(strace -f -T -ttt -e write=1,2 -o "$log" -- "$@")
fi

# Optionally layer perf sampling on top (independent of the ptrace backend — a
# flamegraph is most accurate with the tracer off). Probe `perf record` first so
# a perms failure stays fail-open and the workload still runs.
cmd=("${inner[@]}")
if [ "$use_perf" = "true" ] && [ -n "$run_dir" ] && command -v perf >/dev/null 2>&1 \
    && perf record -o /dev/null -- true >/dev/null 2>&1; then
  cmd=(perf record -g -F 999 -o "$run_dir/perf.data" -- "${inner[@]}")
fi

"${cmd[@]}" &
child=$!

[ -n "$run_dir" ] && printf '%s\n' "$child" > "$run_dir/strace.pid" 2>/dev/null
curl -sf --max-time 1 -X POST "$API/runs/$run_id/pid" \
    -H 'content-type: application/json' -d "{\"pid\":$child}" >/dev/null 2>&1 &

# Catch INT/TERM ourselves so we survive to finalize; the tty already delivered
# the signal to the workload's process group, so it dies on its own.
trap 'kill -INT "$child" 2>/dev/null' INT
trap 'kill -TERM "$child" 2>/dev/null' TERM

rc=0
wait "$child"; rc=$?
# A trap can make `wait` return early while the child is still dying; loop until
# it is really gone so $rc reflects the workload's true exit status.
while kill -0 "$child" 2>/dev/null; do wait "$child"; rc=$?; done

sig_field="null"
if [ "$rc" -gt 128 ]; then
  name="$(kill -l "$((rc - 128))" 2>/dev/null || printf '%s' "$((rc - 128))")"
  sig_field="\"$name\""
fi
ended="$(date +%s%3N 2>/dev/null || true)"
end_payload="{\"exit_code\":$rc,\"exit_signal\":$sig_field"
[ -n "$ended" ] && end_payload="$end_payload,\"ended_at\":$ended"
end_payload="$end_payload}"
curl -sf --max-time 3 -X POST "$API/runs/$run_id/end" \
    -H 'content-type: application/json' -d "$end_payload" >/dev/null 2>&1

exit $rc
